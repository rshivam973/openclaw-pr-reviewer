# =================================================================
# PR Review Bot Configuration
# =================================================================

# --- Required: LLM Provider (at least one key needed) ---
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
LLM_PROVIDER=anthropic
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Required: GitHub ---
GITHUB_PAT=
WEBHOOK_SECRET=

# --- Required: Slack ---
SLACK_BOT_TOKEN=

# Slack channel for all PR review notifications (e.g. #pr-reviews).
# All reviews are posted here + DM to author.
SLACK_PR_REVIEWS_CHANNEL=pr-reviews

# --- Optional ---

# Fallback Slack channel for users that can't be resolved to a DM
SLACK_FALLBACK_CHANNEL=

# GitHub bot username (to skip reviewing the bot's own PRs)
BOT_GITHUB_USERNAME=

# --- Optional: OpenClaw Agent Mode ---
# Routes reviews through an OpenClaw agent for enhanced agentic analysis
# with session memory. Falls back to direct API if OpenClaw is unreachable.
# See openclaw-agent/README.md for setup instructions.
OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_WEBHOOK_TOKEN=
